# Environment variables - Copy this to .env and fill with your values
# NEVER commit .env - it's in .gitignore

# MongoDB Atlas Connection - Sign up at https://www.mongodb.com/cloud/atlas (FREE)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/connex?retryWrites=true&w=majority

# JWT Secret for token signing (use a long random string in production)
JWT_SECRET=your_secure_jwt_secret_min_32_characters_here

# Port for backend server
PORT=5001

# Fast2SMS API key for OTP delivery
FAST2SMS_API_KEY=your_fast2sms_api_key_here

# Show OTP on screen (true during development, false in production)
CONNEX_OTP_IN_RESPONSE=false

# Environment mode
NODE_ENV=development
